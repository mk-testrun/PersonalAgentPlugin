#!/usr/bin/env bash
# pre-push — Dogfooding: dieselbe Qualitätsschranke lokal, die auch CI durchsetzt.
# Aktivieren:  git config core.hooksPath .githooks
# Umgehen:     git push --no-verify   (bewusste Entscheidung, kein Default)
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "pre-push: Validierung (--changed-only --strict gegen origin/main)…"
node tools/validate-plugins.mjs --changed-only origin/main --strict

echo "pre-push: Tool- & Hook-Tests…"
npm run test:tools --silent

# Secret-Scan, falls betterleaks installiert ist (optional — kein Hard-Requirement)
if command -v betterleaks >/dev/null 2>&1; then
  echo "pre-push: betterleaks Secret-Scan…"
  betterleaks git --config .betterleaks.toml 2>/dev/null || betterleaks detect 2>/dev/null || {
    echo "pre-push: betterleaks meldete Findings — Push abgebrochen (--no-verify zum Umgehen)."
    exit 1
  }
fi

echo "pre-push: alles grün."
