{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mk-testrun/PersonalAgentPlugin/docs/schemas/labels.schema.json",
  "title": "policy/labels.json — Label-/Schätz-Kanon (story-author, triage)",
  "type": "object",
  "required": ["severity", "priority", "type", "status"],
  "properties": {
    "severity": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "priority": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "type": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "status": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "storyPoints": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "note": { "type": "string" }
  }
}
