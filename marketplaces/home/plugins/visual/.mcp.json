{
  "mcpServers": {
    "mermaid": {
      "command": "npx",
      "args": ["-y", "@narasimhaponnada/mermaid-mcp-server"]
    },
    "chart": {
      "command": "npx",
      "args": ["-y", "@antv/mcp-server-chart"]
    },
    "excalidraw": {
      "command": "npx",
      "args": ["-y", "excalidraw-mcp"]
    },
    "imagegen": {
      "command": "npx",
      "args": ["-y", "imagegen-mcp"],
      "env": {
        "OPENAI_API_KEY": "${secret:OPENAI_KEY}"
      }
    },
    "artifact-viewer": {
      "command": "artifact-viewer",
      "env": {
        "VIEWER_RICH": "auto",
        "VIEWER_OUT": "${env:USERPROFILE}/.copilot/state/artifacts"
      }
    }
  }
}
