{
  "_credit": "Adapted from mattpocock/skills · git-guardrails-claude-code",
  "_mode": "warn (except force-push main/master → block)",
  "blockAlways": [
    "git push --force.*main",
    "git push --force.*master",
    "git push -f.*main",
    "git push -f.*master"
  ],
  "warn": [
    "git push --force",
    "git push -f",
    "git reset --hard",
    "git clean -fd",
    "git clean -fdx",
    "git branch -D",
    "git checkout -f",
    "git switch -f",
    "git filter-branch",
    "git filter-repo"
  ],
  "allowExceptions": ["force-with-lease"],
  "note": "warn-Modus: Guardrails warnen statt blockieren — Ausnahme: Force-Push auf main/master bleibt block. allowExceptions: --force-with-lease ist erlaubt (ADR-0004). blockAlways sind Regex, warn sind Substrings."
}
