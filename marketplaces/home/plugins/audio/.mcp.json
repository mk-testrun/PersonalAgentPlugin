{
  "mcpServers": {
    "supertonic": {
      "command": "supertonic3-mcp",
      "env": {
        "ST_BASE_URL": "${env:ST_BASE_URL}",
        "ST_DEFAULT_VOICE": "warm-de",
        "ST_OUTPUT_DIR": "${env:USERPROFILE}/.copilot/state/audio"
      }
    },
    "alarm-mcp": {
      "command": "alarm-mcp"
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time"]
    }
  }
}
