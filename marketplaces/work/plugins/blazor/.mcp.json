{
  "mcpServers": {
    "sharplens": {
      "command": "npx",
      "args": ["-y", "sharplens-mcp"],
      "env": {
        "DOTNET_SOLUTION_PATH": "${env:DOTNET_SOLUTION_PATH}"
      }
    },
    "nuget": {
      "command": "dnx",
      "args": ["NuGet.Mcp.Server", "--yes"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${secret:CONTEXT7_KEY}"
      }
    }
  }
}
