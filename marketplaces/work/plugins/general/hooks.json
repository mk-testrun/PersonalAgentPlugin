{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash \"{{plugin_data_dir}}/hooks/scripts/audit-init.sh\"",
        "powershell": "pwsh -File \"{{plugin_data_dir}}/hooks/scripts/audit-init.ps1\"",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "bash \"{{plugin_data_dir}}/hooks/scripts/audit-prompt.sh\"",
        "powershell": "pwsh -File \"{{plugin_data_dir}}/hooks/scripts/audit-prompt.ps1\"",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash \"{{plugin_data_dir}}/hooks/scripts/pre-tool-guardian.sh\"",
        "powershell": "pwsh -File \"{{plugin_data_dir}}/hooks/scripts/pre-tool-guardian.ps1\"",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bash \"{{plugin_data_dir}}/hooks/scripts/audit-tool.sh\"",
        "powershell": "pwsh -File \"{{plugin_data_dir}}/hooks/scripts/audit-tool.ps1\"",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash \"{{plugin_data_dir}}/hooks/scripts/audit-rotate.sh\"",
        "powershell": "pwsh -File \"{{plugin_data_dir}}/hooks/scripts/audit-rotate.ps1\"",
        "timeoutSec": 15
      }
    ]
  }
}
