# Geteilte Editor-Basis (Home + Work) — höchste Priorität hat die dateinächste Sektion.
# VS-Code-User-Settings: editor/vscode/ (via tools/bootstrap.mjs).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Zwei Leerzeichen am Zeilenende sind in Markdown ein Hard-Break.
trim_trailing_whitespace = false
max_line_length = 110

[*.{cs,csproj,props,targets,sln}]
indent_size = 4

[*.{razor,cshtml}]
indent_size = 4

[*.py]
indent_size = 4

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.{yml,yaml,json,mjs,cjs,js,ts,tsx,jsx,css,scss,html}]
indent_size = 2
